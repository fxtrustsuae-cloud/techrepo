# Server
NODE_ENV=development
PORT=5000
FRONTEND_URL=http://localhost:3000

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=techanalysis_db
DB_USER=postgres
DB_PASSWORD=yourpassword

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# Market Data
MARKET_DATA_PROVIDER=twelvedata
MARKET_DATA_FALLBACK_PROVIDER=tradingview
TWELVE_DATA_API_KEY=your_twelve_data_api_key
TWELVE_DATA_CRYPTO_EXCHANGE=Binance

# Email (SMTP or SendGrid)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASS=your_app_password
EMAIL_FROM=reports@techanalysis.com
EMAIL_FROM_NAME=TechAnalysis Pro

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_BASIC=price_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_PREMIUM=price_...

# Report Storage
REPORTS_DIR=./reports
CHARTS_DIR=./charts

# Company Branding
COMPANY_NAME=TechAnalysis Pro
COMPANY_WEBSITE=https://techanalysis.pro
COMPANY_EMAIL=info@techanalysis.pro

# Chromium for PDF (puppeteer)
CHROMIUM_PATH=
